# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# /lib/ and /lib64/ are ANCHORED to the repo root on purpose: they are setuptools
# build outputs created at the project root. Left unanchored (lib/) they also matched
# real source packages anywhere in the tree — e.g. polymarket/research/lib/ — and kept
# that package from ever being committed (broke `from lib.clob_book import ClobBook`
# for anyone who cloned). venv lib/ dirs stay ignored via the venv rules below.
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
venv/
env/
ENV/
.venv

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints/
*.parquet
*.db
*.sqlite
*.xlsx
*.xls

