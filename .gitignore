# OS Files
Thumbs.db
.DS_Store

# Large CPCV simulation files (exceed GitHub 100MB limit)
portfolio_cpcv_paths.pkl
topics/momentum/results/oos/combined_cpcv_paths.pkl
topics/momentum/strategies/bb_cpcv/oos/*_1h_cpcv.pkl
topics/momentum/strategies/bb_cpcv/wf_params/oos/*_1h_cpcv.pkl

# Live trading — runtime data files (never commit live state)
**/trades.json
**/positions.json
**/realised_capital.json
**/mae_cache.json
**/signals_cache.json
**/cache/
cache/
.streamlit/secrets.toml
secrets.toml
# Soak/dry-run journal output (operationally generated, not source-of-truth)
journal_logs/
journal_logs_*/

# polymarket/research (was polymarket-copy/.gitignore — consolidated on restructure)
polymarket/research/data/
polymarket/research/.env
polymarket/research/.venv/
polymarket/research/.tmp/

# Brain (Obsidian vault): TRACK markdown notes so collaborators see new notes via Git automatically.
# Only ignore machine-generated reports, local overlays, and fast-moving per-agent scratch (not source-of-truth).
brain/generated/
brain/.obsidian/
brain/**/.DS_Store

# Per-person agent scratch — LOCAL ONLY: never committed, never on any branch.
# Per-person isolation that keeps branch merges clean (see brain/MERGE_PROTOCOL.md).
/scratch/

# Per-person agent instruction overlays — LOCAL ONLY: never committed, never on any branch.
/local_agents/

# Obsidian volatile session state (personal window layout)
.obsidian/workspace.json

# Safety net: never commit phantom absolute-path trees an agent may create by writing
# to an absolute path as if it were relative (e.g. a mirrored home dir). 2026-06-07 incident.
/Users/
/home/
/private/
